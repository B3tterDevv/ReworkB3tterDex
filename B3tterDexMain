local function UpdateEnemyDropdown()
    if not EnemyDropdown then return end
    local enemyNames = GetEnemyNamesFromFrames()
    local NewOptions = {}
    for _, name in ipairs(enemyNames) do
        table.insert(NewOptions, name)
    end
    table.sort(NewOptions)
    local NeedsRefresh = false
    if #NewOptions ~= #CurrentEnemyOptions then NeedsRefresh = true
    else
        for i, Name in ipairs(NewOptions) do
            if CurrentEnemyOptions[i] ~= Name then NeedsRefresh = true break end
        end
    end
    if NeedsRefresh then
        CurrentEnemyOptions = NewOptions
        EnemyDropdown:Refresh(NewOptions)
    end
end

local FastGunSpamAllActive = false
local FastGunSpamAllThreads = {}

local function StopFastGunSpamAll()
    FastGunSpamAllActive = false
    for _, thread in ipairs(FastGunSpamAllThreads) do
        pcall(task.cancel, thread)
    end
    FastGunSpamAllThreads = {}
end

local function FastFireGunAll()
    if not FastGunSpamAllActive then return end
    local enemies = GetEnemyPlayers()
    for _, plr in ipairs(enemies) do
        if not FastGunSpamAllActive then break end
        if plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") and plr.Character:FindFirstChild("Humanoid") and plr.Character.Humanoid.Health > 0 then
            local hasGun, gun = HasWeaponEquipped()
            if not hasGun and AutoEquipEnabled then
                gun = EquipGun()
            end
            if gun then
                local pos = GetPredictedPosition(plr)
                if pos then
                    Shoot(plr, pos, true)
                    task.wait(0.001)
                end
            end
        end
        task.wait(0.001)
    end
end

local function StartFastGunSpamAll()
    if FastGunSpamAllActive then return end
    StopFastGunSpamAll()
    FastGunSpamAllActive = true
    
    for i = 1, 7 do
        local thread = task.spawn(function()
            while FastGunSpamAllActive do
                FastFireGunAll()
                task.wait(0.001)
            end
        end)
        table.insert(FastGunSpamAllThreads, thread)
        task.wait(0.001)
    end
end

