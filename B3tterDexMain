local AutoSaveFolder = "B3tterDex/Rayfield/CustomAutoSave"
local AutoSaveFile = AutoSaveFolder .. "/my_settings.txt"

local function LoadAutoSave()
    if not isfolder(AutoSaveFolder) then makefolder(AutoSaveFolder) end
    if isfile(AutoSaveFile) then
        local content = readfile(AutoSaveFile)
        if content then
            local sp, ep = string.find(content, "{"), string.find(content, "}")
            if sp and ep then
                local ds = string.sub(content, sp+1, ep-1)
                local parts = {}
                for part in string.gmatch(ds, "[^,]+") do
                    local k, v = string.match(part, "([^=]+)=(.+)")
                    if k and v then parts[k] = v end
                end
                return parts
            end
        end
    end
    return {}
end

local function SaveAutoSave(settings)
    if not isfolder(AutoSaveFolder) then makefolder(AutoSaveFolder) end
    local parts = {}
    for k, v in pairs(settings) do table.insert(parts, k .. "=" .. tostring(v)) end
    writefile(AutoSaveFile, "SavingVar = {" .. table.concat(parts, ",") .. "}")
end

local SavedSettings = LoadAutoSave()

local function GetSetting(name, default)
    local val = SavedSettings[name]
    if val == nil then return default end
    if val == "true" then return true
    elseif val == "false" then return false
    else local num = tonumber(val) return num or val end
end

local function UpdateSetting(name, value)
    SavedSettings[name] = tostring(value)
    pcall(SaveAutoSave, SavedSettings)
end

