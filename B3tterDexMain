local function TweenToFar(rootPart)
    if ActiveTween then
        ActiveTween:Cancel()
        ActiveTween = nil
    end
    if not rootPart or not rootPart.Parent then return end
    rootPart.Anchored = true
    rootPart.CanCollide = false
    rootPart.CanTouch = false
    rootPart.CanQuery = false
    rootPart.Massless = true
    rootPart.Velocity = Vector3.zero
    rootPart.RotVelocity = Vector3.zero

    local function tweenTo(targetCF, waitTime)
        if not rootPart.Parent then return false end
        if waitTime > 0 then task.wait(waitTime) end
        if not rootPart.Parent then return false end
        local distance = (rootPart.Position - targetCF.Position).Magnitude
        local duration = distance / TWEEN_SPEED
        if duration <= 0 then duration = 0.01 end
        local tweenInfo = TweenInfo.new(duration, Enum.EasingStyle.Linear, Enum.EasingDirection.Out)
        local tween = TweenService:Create(rootPart, tweenInfo, {CFrame = targetCF})
        ActiveTween = tween
        tween:Play()
        local completed = tween.Completed:Wait()
        ActiveTween = nil
        return completed ~= Enum.TweenStatus.Cancelled
    end

    tweenTo(POS1, 0)
    tweenTo(POS2, 2.8)
end

local function GiveCloak()
    if CloakTool and CloakTool.Parent and CloakTool:IsDescendantOf(LocalPlayer) then
        Rayfield:Notify({Title = "Cloak", Content = lang.AlreadyHaveCloak, Duration = 2})
        return
    end
    local Tool = Instance.new("Tool")
    Tool.Name = "B3tterDex Invisibility Cloak"
    Tool.RequiresHandle = false
    Tool.Parent = LocalPlayer.Backpack
    CloakTool = Tool
    local Active = false
    local RealHRP, FakeHRP, Humanoid, Loop, deathConn
    local Velocity = Vector3.zero
    local SPEED = CloakSpeed
    local ACCEL = CloakAccel

    local function EndCloak(teleportToFake)
        if Loop then Loop:Disconnect() end
        if deathConn then deathConn:Disconnect() end
        if ActiveTween then
            ActiveTween:Cancel()
            ActiveTween = nil
        end
        if Humanoid then
            Camera.CameraSubject = Humanoid
        end
        if RealHRP and FakeHRP then
            for _, child in ipairs(RealHRP:GetChildren()) do
                if child:IsA("BodyVelocity") or child:IsA("BodyGyro") or child:IsA("AlignPosition") or child:IsA("Attachment") then
                    child:Destroy()
                end
            end
            if teleportToFake then
                RealHRP.CFrame = FakeHRP.CFrame
                RealHRP.AssemblyLinearVelocity = Vector3.zero
                RealHRP.AssemblyAngularVelocity = Vector3.zero
            end
            RealHRP.Anchored = false
            RealHRP.CanCollide = true
        end
        if FakeHRP then FakeHRP:Destroy() end
        Active = false
    end

    Tool.Equipped:Connect(function()
        if Active then return end
        Active = true
        local Character = LocalPlayer.Character
        if not Character then return end
        Humanoid = Character:FindFirstChildOfClass("Humanoid")
        RealHRP = Character:FindFirstChild("HumanoidRootPart")
        if not Humanoid or not RealHRP then return end

        deathConn = Humanoid.Died:Connect(function()
            if Tool and Tool.Parent then
                Tool.Parent = nil
            end
            EndCloak(true)
        end)

        FakeHRP = CreateFakePart(RealHRP)

        for _, c in ipairs(RealHRP:GetChildren()) do
            if c:IsA("BodyVelocity") or c:IsA("BodyGyro") or c:IsA("AlignPosition") or c:IsA("Attachment") then
                c:Destroy()
            end
        end

        TweenToFar(RealHRP)

        Camera.CameraSubject = FakeHRP

        Loop = RunService.RenderStepped:Connect(function(dt)
            if not Active then return end
            local cam = Camera.CFrame
            local look = cam.LookVector
            local right = cam.RightVector
            local up = cam.UpVector
            local move = Control:GetMoveVector()
            local dir = Vector3.zero
            if move.Z < 0 then dir += look elseif move.Z > 0 then dir -= look end
            if move.X > 0 then dir += right elseif move.X < 0 then dir -= right end
            if UserInputService:IsKeyDown(Enum.KeyCode.Space) then dir += up end
            if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then dir -= up end
            local targetVelocity = dir.Magnitude > 0 and dir.Unit * SPEED or Vector3.zero
            Velocity = Velocity:Lerp(targetVelocity, math.clamp(dt * ACCEL, 0, 1))
            local targetPos = FakeHRP.Position + Velocity
            FakeHRP.CFrame = FakeHRP.CFrame:Lerp(CFrame.new(targetPos, targetPos + cam.LookVector), math.clamp(dt * 6, 0, 1))
        end)
    end)

    Tool.Unequipped:Connect(function()
        EndCloak(true)
    end)

    Rayfield:Notify({Title = "Cloak", Content = lang.GiveCloak, Duration = 2})
end

local function GiveFakeLag()
    if FakeLagTool and FakeLagTool.Parent and FakeLagTool:IsDescendantOf(LocalPlayer) then
        Rayfield:Notify({Title = "Fake Lag", Content = lang.AlreadyHaveFakeLag, Duration = 2})
        return
    end
    local Tool = Instance.new("Tool")
    Tool.Name = "Fake Lag"
    Tool.RequiresHandle = false
    Tool.Parent = LocalPlayer.Backpack
    FakeLagTool = Tool
    local Active = false
    local RealHRP, FakeHRP_2, Humanoid, Loop, AnimationTrack
    local SPEED = CloakSpeed
    local ACCEL = CloakAccel
    local Velocity = Vector3.zero
    Tool.Equipped:Connect(function()
        if Active then return end
        Active = true
        local Character = LocalPlayer.Character
        if not Character then return end
        Humanoid = Character:FindFirstChildOfClass("Humanoid")
        RealHRP = Character:FindFirstChild("HumanoidRootPart")
        if not Humanoid or not RealHRP then return end
        RealHRP.Anchored = true
        local animId, track = GetMyCurrentAnimation()
        if track then AnimationTrack = track AnimationTrack:Play() end
        FakeHRP_2 = CreateFakePart(RealHRP)
        Camera.CameraSubject = FakeHRP_2
        Loop = RunService.RenderStepped:Connect(function(dt)
            local cam = Camera.CFrame
            local look = cam.LookVector
            local right = cam.RightVector
            local up = cam.UpVector
            local move = Control:GetMoveVector()
            local dir = Vector3.zero
            if move.Z < 0 then dir += look elseif move.Z > 0 then dir -= look end
            if move.X > 0 then dir += right elseif move.X < 0 then dir -= right end
            if UserInputService:IsKeyDown(Enum.KeyCode.Space) then dir += up end
            if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then dir -= up end
            local targetVelocity = dir.Magnitude > 0 and dir.Unit * SPEED or Vector3.zero
            Velocity = Velocity:Lerp(targetVelocity, math.clamp(dt * ACCEL, 0, 1))
            local targetPos = FakeHRP_2.Position + Velocity
            FakeHRP_2.CFrame = FakeHRP_2.CFrame:Lerp(CFrame.new(targetPos, targetPos + cam.LookVector), math.clamp(dt * 6, 0, 1))
        end)
    end)
    Tool.Unequipped:Connect(function()
        Active = false
        if Loop then Loop:Disconnect() end
        if Humanoid then Camera.CameraSubject = Humanoid end
        if AnimationTrack then AnimationTrack:Stop() AnimationTrack = nil end
        if RealHRP and FakeHRP_2 then
            RealHRP.CFrame = FakeHRP_2.CFrame
            RealHRP.AssemblyLinearVelocity = Vector3.zero
        end
        if RealHRP then RealHRP.Anchored = false end
        if FakeHRP_2 then FakeHRP_2:Destroy() end
    end)
    Rayfield:Notify({Title = "Fake Lag", Content = lang.GiveFakeLag, Duration = 2})
end

