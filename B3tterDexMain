local function GetTeamMates()
    local MyTeam = GetLocalTeam()
    if not MyTeam then return {} end
    local myGame = GetLocalGame()
    local list = {}
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr:GetAttribute("Game") == myGame and plr:GetAttribute("Team") == MyTeam then
