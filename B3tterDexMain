    local _, _, handle = getEquippedKnife()
    if not handle then
        if autoEquipKnife then EquipKnifeForThrow() end
        return false
    end
    for _ = 1, 7 do
        if handle and handle.Position ~= Vector3.zero then return true end
        task.wait(0.05)
        _, _, handle = getEquippedKnife()
    end
    return handle ~= nil and handle.Position ~= Vector3.zero
end

local function getComp(object, componentName)
    local cacheKey = tostring(object) .. "_" .. componentName
    local cached = cachedComponents[cacheKey]
    if cached and cached.time > tick() - CACHE_INTERVAL then return cached.component end
    local component = object:FindFirstChild(componentName)
    cachedComponents[cacheKey] = { component = component, time = tick() }
    return component
end

local function validWeap(weapon)
    if not weapon then return false end
    local valid = pcall(function() return weapon:IsDescendantOf(game) and weapon.Parent ~= nil end)
    if not valid then return false end
    return getComp(weapon, "fire") ~= nil
end

local BeamBindable = nil
local function GetBeamBindable()
    if BeamBindable and BeamBindable.Parent then
        return BeamBindable
    end
    
    local bindableEvents = ReplicatedStorage:FindFirstChild("BindableEvents")
    if bindableEvents then
        local beam = bindableEvents:FindFirstChild("LocalBeam")
        if beam and beam:IsA("BindableEvent") then
            BeamBindable = beam
            return beam
        end
    end
    
    for _, child in ipairs(ReplicatedStorage:GetChildren()) do
        if child.Name == "LocalBeam" and child:IsA("BindableEvent") then
            BeamBindable = child
            return child
        end
    end
    
    BeamBindable = nil
    return nil
end

local ToolCache = setmetatable({}, {__mode = "k"})

local function GetToolEvents(tool)
    local cached = ToolCache[tool]
    if cached then return cached end
    
    local fireEvent = tool:FindFirstChild("fire") or tool:FindFirstChild("Fire")
    if not fireEvent then return nil end
    
    local events = {
        fire = fireEvent,
        showBeam = tool:FindFirstChild("showBeam"),
        kill = tool:FindFirstChild("kill") or tool:FindFirstChild("Kill"),
        handle = tool:FindFirstChild("Handle") or tool
    }
    
    ToolCache[tool] = events
    return events
end

local function Shoot(Target, Pos)
    local character = LocalPlayer.Character
    if not character then return false end
    
    local humanoidRootPart = character:FindFirstChild("HumanoidRootPart")
    if not humanoidRootPart then return false end
    
    local toolEvents = nil
    for _, tool in ipairs(character:GetChildren()) do
        if tool:IsA("Tool") then
            toolEvents = GetToolEvents(tool)
            if toolEvents then break end
        end
    end
    
    if not toolEvents then return false end
    
    pcall(function()
        toolEvents.fire:FireServer()
    end)
    
    local beam = GetBeamBindable()
    if beam then
        pcall(function()
            beam:Fire(toolEvents.handle, Pos)
        end)
    end
    
    if toolEvents.showBeam then
        pcall(function()
            toolEvents.showBeam:FireServer(Pos, humanoidRootPart.Position, toolEvents.handle)
        end)
    end
    
    if UseGunKill then
        GunKill(Target, Pos)
    else
        KnifeKill(Target)
    end
    
    return true
end

local function FastFireTarget(forceTarget)
    if not AutoShootEnabled then return end
    
    local now = tick()
    local cooldown = COOLDOWN_BASE + (GetPing() / 1000)
    if now - lastShotTime < cooldown then return end
    
    local Target = forceTarget or GetClosestPlayer()
    if not Target then
        if AutoUnEquipEnabled then UnequipGun() end
        return
    end
    if not AllowShootingWhereYouDontLooking and not LookingEnemy(Target) then
        if AutoUnEquipEnabled then UnequipGun() end
        return
    end
    if not IfISeeTarget(Target) then
        if AutoUnEquipEnabled then UnequipGun() end
        return
    end
    local Pos = GetPredictedPosition(Target)
    if not Pos then
        if AutoUnEquipEnabled then UnequipGun() end
        return
    end
    local Eq, Tool = HasWeaponEquipped()
    if not Eq then
        if AutoEquipEnabled then
            Tool = EquipGun()
            if not Tool or Tool.Parent ~= LocalPlayer.Character then return end
        else
            if AutoUnEquipEnabled then UnequipGun() end
            return
        end
    end
    
    if not validWeap(Tool) then
        if AutoUnEquipEnabled then UnequipGun() end
        return
    end
    
    Shoot(Target, Pos)
    lastShotTime = now
    
    if AutoUnEquipEnabled then
        task.delay(0.008, function()
            if CurrentGun and CurrentGun.Parent == LocalPlayer.Character then
                UnequipGun()
            end
        end)
    end
end

