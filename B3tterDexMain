local Safe_Request = (syn and syn.request) or (http and http.request) or http_request or request

local function SafeHttpGet(url, retries)
    retries = retries or 2
    if not Safe_Request or type(url) ~= "string" then return nil end
    for i = 1, retries do
        local ok, res = pcall(Safe_Request, {Url = url, Method = "GET"})
        if ok and res and (res.Success == nil or res.Success) and type(res.Body) == "string" then
            return res.Body
        end
        task.wait(0.3 * i)
    end
    return nil
end

local function Base64Decode(data)
    local chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/"
    data = data:gsub("[^" .. chars .. "=]", "")
    return (data:gsub(".", function(byte)
        if byte == "=" then return "" end
        local index = chars:find(byte, 1, true) - 1
        local bits = ""
        for i = 6, 1, -1 do
            bits = bits .. ((index % 2^i - index % 2^(i - 1) > 0) and "1" or "0")
        end
        return bits
    end):gsub("%d%d%d?%d?%d?%d?%d?%d?", function(bits)
        if #bits ~= 8 then return "" end
        local char = 0
        for i = 1, 8 do
            if bits:sub(i, i) == "1" then
                char = char + 2^(8 - i)
            end
        end
        return string.char(char)
    end))
end

local function DecodeBase64(str)
    local success, result = pcall(function()
        if base64decode then return base64decode(str)
        elseif crypt and crypt.base64decode then return crypt.base64decode(str)
        elseif syn and syn.crypt and syn.crypt.base64 and syn.crypt.base64.decode then
            return syn.crypt.base64.decode(str)
        else return Base64Decode(str) end
    end)
    return success and result or Base64Decode(str)
end

