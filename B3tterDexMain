local function Shoot2Die(ignoreSlide)
    if not Shoot2DieEnabled and not ignoreSlide then return end
    local target = GetClosestEnemyByMouse()
    if not target then return end
    if Shoot2DieToClick2Die then
        PerformKnifeKill(target)
        if not ignoreSlide then
            Rayfield:Notify({Title = lang.Click2DieTitle, Content = string.format(lang.Click2DieContent, target.Name), Duration = 2})
        end
        return
    end
    PerformKnifeKill(target)
    local Tool, KillRemote = GetToolWithKill()
    if KillRemote and Tool and Tool:FindFirstChild("Handle") then
        local direction = (target.Character.HumanoidRootPart.Position - Tool.Handle.Position).Unit
        for _ = 1, 25 do pcall(function() KillRemote:FireServer(target, direction) end) end
    end
    local Eq, GunTool = HasWeaponEquipped()
    if not Eq and AutoEquipEnabled then GunTool = EquipGun() end
    if GunTool then
        local pos = GetPredictedPosition(target)
        if pos then for _ = 1, 15 do Shoot(target, pos) end end
    end
    if not ignoreSlide then
        Rayfield:Notify({Title = lang.Shoot2DieTitle, Content = string.format(lang.Shoot2DieContent, target.Name), Duration = 2, Image = "target"})
    end
end

