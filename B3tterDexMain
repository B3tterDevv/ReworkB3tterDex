    if not ensureKnifeReady() then
        if autoUnequipKnife then UnequipKnife() end
        return
    end
    ThrowKill(target, nil, nil, true)
    if autoUnequipKnife then
        task.defer(function()
            UnequipKnife()
        end)
    end
end

