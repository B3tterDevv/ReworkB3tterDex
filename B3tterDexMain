local function getClosestVisibleEnemyForKnife()
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return nil end
    local origin = char.HumanoidRootPart.Position
    local enemies = GetEnemyPlayers()
    local best, bestDist = nil, knifeDetectionDist
    for _, enemy in ipairs(enemies) do
        local enemyChar = enemy.Character
        if enemyChar then
            local hrp = enemyChar:FindFirstChild("HumanoidRootPart")
            if hrp then
                local dist = (hrp.Position - origin).Magnitude
                if dist <= bestDist and IfISeeTarget(enemy) then
                    bestDist = dist
                    best = enemy
                end
            end
        end
    end
    return best
end

local function FastThrowKnife()
    if not autoThrow then return end
    local target = getClosestVisibleEnemyForKnife()
    if not target then
        if autoUnequipKnife then UnequipKnife() end
