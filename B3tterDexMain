local autoExecuteEnabled = GetSetting("AutoExecuteEnabled", false)

local function setupAutoExecute()
    if not autoExecuteEnabled then return end
    local teleportFunc = queue_on_teleport or (syn and syn.queue_on_teleport) or (fluxus and fluxus.queue_on_teleport)
    if teleportFunc then
        local scriptToRun = [[
            local Safe_Request = (syn and syn.request) or (http and http.request) or http_request or request
            local function SafeHttpGet(url, retries)
                retries = retries or 2
                if not Safe_Request or type(url) ~= "string" then return nil end
                for i = 1, retries do
                    local ok, res = pcall(Safe_Request, {Url = url, Method = "GET"})
                    if ok and res and (res.Success == nil or res.Success) and type(res.Body) == "string" then
                        return res.Body
                    end
                    task.wait(0.3 * i)
                end
                return nil
            end
            local function Base64Decode(data)
                local chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/"
                data = data:gsub("[^" .. chars .. "=]", "")
