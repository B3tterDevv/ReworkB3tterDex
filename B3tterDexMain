local function getTeamFramesFromGui()
    local playerGui = LocalPlayer:FindFirstChildOfClass("PlayerGui")
    if not playerGui then return nil, nil end
    local main = playerGui:FindFirstChild("Main")
    if not main then return nil, nil end
    local mainGameFrame = main:FindFirstChild("MainGameFrame")
    if not mainGameFrame then return nil, nil end
    local playersFrame = mainGameFrame:FindFirstChild("PlayersFrame")
    if not playersFrame then return nil, nil end
    return playersFrame:FindFirstChild("TeamRedFrame"), playersFrame:FindFirstChild("TeamBlueFrame")
end

local function GetEnemyNamesFromFrames()
    local redFrame, blueFrame = getTeamFramesFromGui()
    if not redFrame or not blueFrame then return {} end
    local function getNames(frame)
        local names = {}
        if not frame then return names end
        for _, child in ipairs(frame:GetChildren()) do
            if child:IsA("Frame") or child:IsA("TextLabel") then
                table.insert(names, child.Name)
            end
        end
        return names
    end
    local redList = getNames(redFrame)
    local blueList = getNames(blueFrame)
    local localName = LocalPlayer.Name
    local amRed = false
    for _, name in ipairs(redList) do
        if name == localName then amRed = true break end
    end
    local amBlue = false
    for _, name in ipairs(blueList) do
        if name == localName then amBlue = true break end
    end
    if not amRed and not amBlue then return {} end
    return amRed and blueList or redList
end

local function GetPing()
    local T = tick()
    if T - LastPingUpdate > 0.1 then
        local Ok, Res = pcall(function() return Stats.Network.ServerStatsItem["Data Ping"]:GetValue() end)
        if Ok then CachedPing = Res end
        LastPingUpdate = T
    end
    return CachedPing or 30
end

local function LookingEnemy(Target)
    if not Target or not Target.Character then return false end
    local TargetCharacter = Target.Character
    local TargetHumanoidRootPart = TargetCharacter:FindFirstChild("HumanoidRootPart")
    if not TargetHumanoidRootPart then return false end
    local Position = TargetHumanoidRootPart.Position
    local FOV = 90
    local Character = LocalPlayer.Character
    if not Character then return false end
    local HRP = Character:FindFirstChild("HumanoidRootPart")
    if not HRP then return false end
    local Origin = Camera.CFrame.Position
    local Direction = Position - Origin
    local Distance = Direction.Magnitude
    if Distance <= 0 then return false end
    local UnitDir = Direction / Distance
    local Look = Camera.CFrame.LookVector
    local Threshold = math.cos(math.rad(FOV * 0.5))
    if Look:Dot(UnitDir) < Threshold then return false end
    local Params = RaycastParams.new()
    Params.FilterDescendantsInstances = {Character, TargetCharacter}
    Params.FilterType = Enum.RaycastFilterType.Blacklist
    local Result = Workspace:Raycast(Origin, Direction, Params)
    if not Result then return true end
    return (Result.Position - Position).Magnitude < 2
end

local function GetBox(Part, Origin, Tries)
    local Cf = Part.CFrame
    local Size = Part.Size * 0.5
    local Best = nil
    local Vel = Part.AssemblyLinearVelocity or Vector3.new()
    local Right = Cf.RightVector
    local Up = Cf.UpVector
    local Look = Cf.LookVector
    local Rdot = Vel:Dot(Right)
    local Udot = Vel:Dot(Up)
    local Ldot = Vel:Dot(Look)
    for I = 1, Tries do
        local Rx = (math.random() - 0.5) * 2
        local Ry = (math.random() - 0.5) * 2
        local Rz = (math.random() - 0.5) * 2
        if math.abs(Rdot) > 0.1 then Rx = Rdot > 0 and math.abs(Rx) or -math.abs(Rx) else Rx = Rx * 0.25 end
        if math.abs(Udot) > 0.1 then Ry = Udot > 0 and math.abs(Ry) or -math.abs(Ry) else Ry = Ry * 0.25 end
        if math.abs(Ldot) > 0.1 then Rz = Ldot > 0 and math.abs(Rz) or -math.abs(Rz) else Rz = Rz * 0.25 end
        local Point = Cf.Position + Right * (Rx * Size.X) + Up * (Ry * Size.Y) + Look * (Rz * Size.Z)
        local Dir = (Cf.Position - Origin).Unit
        Point = Point + Dir * 0.05
        if not Best or (Point - Origin).Magnitude < (Best - Origin).Magnitude then Best = Point end
    end
    return Best
end

local function changePos(coord)
    if math.abs(coord) > 1e7 then return coord > 0 and 1e6 or -1e6 end
    return coord
end

local function GetPredictedPosition(Player)
    if not Player or not Player.Character then return nil end
    local Target = Player.Character
    local Part = Target:FindFirstChild("HumanoidRootPart")
    if not Part then return nil end

    local LocalChar = LocalPlayer.Character
    if not LocalChar then return nil end
    local OriginPart = LocalChar:FindFirstChild("HumanoidRootPart")
    if not OriginPart then return nil end

    local currentPos = GetBox(Part, OriginPart.Position, 5) or Part.Position
    local targetVel = Part.AssemblyLinearVelocity or Vector3.new()
    local originPos = OriginPart.Position
    local Cf = Part.CFrame
    local Look = Cf.LookVector
    local Angular = Part.AssemblyAngularVelocity or Vector3.new()

    local function __quadratic(a, b, c)
        local d = b * b - 4 * a * c
        if d < 0 then return nil end
        local sqrtD = math.sqrt(d)
        local t1 = (-b - sqrtD) / (2 * a)
        local t2 = (-b + sqrtD) / (2 * a)
        if t1 > 0 and t2 > 0 then return math.min(t1, t2)
        elseif t1 > 0 then return t1
        elseif t2 > 0 then return t2 end
        return nil
    end

    local function FindLeadShot(shooterPos, targetPos, targetVel, projSpeed, gravity)
        local r = targetPos - shooterPos
        local v = targetVel
        local a = Vector3.new(0, -gravity, 0)
        local A = 0.25 * a:Dot(a)
        local B = a:Dot(v) - r:Dot(a)
        local C = v:Dot(v) - 2 * r:Dot(v) - projSpeed * projSpeed
        local t = __quadratic(A, B, C)
        if not t or t < 0 then return nil end
        local predicted = targetPos + v * t + 0.5 * a * t * t
        return predicted, t
    end

    local pingComp = GetPing() / 1000
    local extraDelay = 0.08
    local totalDelay = pingComp + extraDelay

    local predicted, t = FindLeadShot(originPos, currentPos, targetVel, 1e6, 0)

    if predicted and t and t > 0 then
        predicted = predicted + targetVel * totalDelay
    else
        predicted = currentPos + targetVel * totalDelay
    end

    local Forward = targetVel:Dot(Look)
    if Forward > 0 then
        predicted = predicted + Look * (Forward * 0.025)
    end

    if Angular and Angular.Magnitude > 0.2 and targetVel.Magnitude > 0.5 then
        local Rel = predicted - currentPos
        if Rel.Magnitude > 0 then
            predicted = predicted + Angular.Unit:Cross(Rel.Unit) * Rel.Magnitude * 0.25
        end
    end

    predicted = Vector3.new(changePos(predicted.X), changePos(predicted.Y), changePos(predicted.Z))
    return predicted
end

local Camera = Workspace.CurrentCamera

local RayParams = RaycastParams.new()
RayParams.FilterType = Enum.RaycastFilterType.Blacklist
RayParams.IgnoreWater = true

local FOVRadius = 300
local FOVRadiusSquared = FOVRadius * FOVRadius

local function Visible(Origin, Position, Character)
    local Result = Workspace:Raycast(Origin, Position - Origin, RayParams)

    return not Result or Result.Instance:IsDescendantOf(Character)
end

local function IfISeeTarget(Player)
    if not Player then
        return false
    end

    local LocalCharacter = LocalPlayer.Character
    local Character = Player.Character

    if not LocalCharacter or not Character then
        return false
    end

    local LocalHRP = LocalCharacter:FindFirstChild("HumanoidRootPart")
    local TargetHRP = Character:FindFirstChild("HumanoidRootPart")

    if not LocalHRP or not TargetHRP then
        return false
    end

    local ScreenPos, VisibleOnScreen = Camera:WorldToViewportPoint(TargetHRP.Position)

    if not VisibleOnScreen then
        return false
    end

    local Viewport = Camera.ViewportSize

    local DX = ScreenPos.X - (Viewport.X * 0.5)
    local DY = ScreenPos.Y - (Viewport.Y * 0.5)

    if (DX * DX + DY * DY) > FOVRadiusSquared then
        return false
    end

    RayParams.FilterDescendantsInstances = {LocalCharacter}

    local CameraOrigin = Camera.CFrame.Position

    if not Visible(CameraOrigin, TargetHRP.Position, Character) then
        return false
    end

    if not Visible(LocalHRP.Position, TargetHRP.Position, Character) then
        return false
    end

    for i = 1, #BodyParts do
        local Part = Character:FindFirstChild(BodyParts[i])

        if Part and Part:IsA("BasePart") then
            local Point = GetBox(Part, CameraOrigin, MaxRaycastAttempts)

            if Visible(CameraOrigin, Point, Character) then
                return true
            end
        end
    end

    return false
end

local function GetClosestPlayer()
    local char = LocalPlayer.Character
    if not char then return nil end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end
    local best = nil
    local bestScore = math.huge
    local ping = GetPing()
    local dynamicDist = AimDistance * (1 - math.min(0.35, ping / 400))
    for _, enemy in ipairs(GetEnemyPlayers()) do
        local enemyChar = enemy.Character
        if enemyChar then
            local targetHrp = enemyChar:FindFirstChild("HumanoidRootPart")
            local hum = enemyChar:FindFirstChild("Humanoid")
            if targetHrp and hum and hum.Health > 0 then
                local dist = (targetHrp.Position - hrp.Position).Magnitude
                if dist <= dynamicDist then
                    local visible = IfISeeTarget(enemy)
                    local angle = (targetHrp.Position - Camera.CFrame.Position).Unit:Dot(Camera.CFrame.LookVector)
                    local vel = targetHrp.AssemblyLinearVelocity or Vector3.new()
                    local speed = vel.Magnitude
                    local score = dist
                    if not visible then score = score * 1.6 end
                    if angle < 0.3 then score = score * 1.4 end
                    if speed > 15 then score = score * 0.85 end
                    if score < bestScore then
                        bestScore = score
                        best = enemy
                    end
                end
            end
        end
    end
    return best
end

