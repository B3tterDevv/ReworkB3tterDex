local function getAbsoluteDevice()
    local info = {Device = "Desktop", IsEmulator = false}
    if GuiService:IsTenFootInterface() then info.Device = "Console" return info end
    if UserInputService.TouchEnabled then
        local vp = Camera.ViewportSize
        info.Device = (vp.X > 1000 or vp.Y > 600) and "Tablet" or "Phone"
        if not UserInputService.AccelerometerEnabled then info.IsEmulator = true end
        if UserInputService.KeyboardEnabled and UserInputService.MouseEnabled then info.IsEmulator = true end
        return info
    end
    return info
end

