local function GetLocalTeam()
    local teamAttr = LocalPlayer:GetAttribute("Team")
    if teamAttr and (teamAttr == "TeamRed" or teamAttr == "TeamBlue") then return teamAttr end
    return nil
end

local function GetTeamMates()
    local MyTeam = GetLocalTeam()
    if not MyTeam then return {} end
    local list = {}
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr:GetAttribute("Team") == MyTeam then
            local char = plr.Character
            if char and char:FindFirstChild("Humanoid") and char.Humanoid.Health > 0 then
                table.insert(list, plr)
            end
        end
    end
    return list
end

local function GetEnemyTeam()
    local MyTeam = GetLocalTeam()
    if not MyTeam then return nil end
    return MyTeam == "TeamRed" and "TeamBlue" or "TeamRed"
end

local function GetEnemyPlayers()
    local EnemyTeam = GetEnemyTeam()
    if not EnemyTeam then return {} end
    local List = {}
    for _, Player in ipairs(Players:GetPlayers()) do
        if Player ~= LocalPlayer then
            local Character = Player.Character
            if Character then
                local Humanoid = Character:FindFirstChild("Humanoid")
                if Humanoid and Humanoid.Health > 0 then
                    if Player:GetAttribute("Team") == EnemyTeam then table.insert(List, Player) end
                end
            end
        end
    end
    return List
end

local remoteCache = {}
local cacheTime = 0
local function GetRemotes()
    if #remoteCache > 0 and tick() - cacheTime < 1 then
        return remoteCache
    end
    remoteCache = {}
    for _, child in ipairs(Net:GetChildren()) do
        if child:IsA("RemoteEvent") and string.sub(child.Name, 1, 3) == "RE/" then
            remoteCache[#remoteCache + 1] = child
        end
    end
    cacheTime = tick()
    return remoteCache
end

local function FireRemote(remote, target)
    pcall(function()
        remote:FireServer("bb15e94b-1af0-48fe-be2b-b2f9e007565a", target)
    end)
end


local function KnifeKill(target)
    if not target then return end
    local remotes = GetRemotes()
    if #remotes == 0 then return end
    for _, remote in ipairs(remotes) do
        FireRemote(remote, target)
        task.wait(0.00003)
    end
end

local KillAll = function(enabled)
    if enabled == nil then enabled = true end
    if not enabled then
        getgenv()._killAllActive = false
        return
    end
    if getgenv()._killAllActive then return end
    getgenv()._killAllActive = true
    local plrs = Players
    local lp = LocalPlayer
    task.spawn(function()
        while getgenv()._killAllActive do
            local enemyTeam = GetEnemyTeam()
            if enemyTeam then
                local enemies = {}
                for _, plr in ipairs(plrs:GetPlayers()) do
                    if plr ~= lp and plr:GetAttribute("Team") == enemyTeam then
                        local char = plr.Character
                        if char and char.Parent then
                            local hum = char:FindFirstChildOfClass("Humanoid")
                            if hum and hum.Health > 0 then
                                enemies[#enemies + 1] = plr
                            end
                        end
                    end
                end
                if #enemies > 0 then
                    local remotes = GetRemotes()
                    if #remotes > 0 then
                        for _, enemy in ipairs(enemies) do
                            task.spawn(function()
                                for _, remote in ipairs(remotes) do
                                    if not getgenv()._killAllActive then break end
                                    FireRemote(remote, enemy)
                                end
                            end)
                        end
                    end
                end
            end
            task.wait(0.0000000001)
        end
    end)
end

