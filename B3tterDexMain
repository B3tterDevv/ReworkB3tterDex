                    Highlight.OutlineColor = Color3.fromRGB(255,255,255)
                    Highlight.FillColor = Color
                    Highlight.Adornee = Character
                    Highlight.Parent = Character
                    Highlights[Player] = Highlight
                else
                    local Highlight = Highlights[Player]
                    Highlight.Adornee = Character
                    Highlight.FillColor = Color
                    Highlight.Parent = Character
                end
            end
        end
    end
    for Player, Highlight in pairs(Highlights) do
        if not CurrentEnemies[Player] then
            if Highlight then pcall(function() Highlight:Destroy() end) end
            Highlights[Player] = nil
        end
    end
    if EspTeamMatesEnabled then
        local CurrentTeamMates = {}
        for _, Player in ipairs(GetTeamMates()) do
            CurrentTeamMates[Player] = true
            local Character = Player.Character
            if Character then
                local Humanoid = Character:FindFirstChild("Humanoid")
                if Humanoid and Humanoid.Health > 0 then
                    local MyTeam = GetLocalTeam()
                    local Color = MyTeam == "TeamRed" and Color3.fromRGB(255,100,100) or Color3.fromRGB(100,100,255)
                    if not TeamMatesHighlights[Player] or not TeamMatesHighlights[Player].Parent then
                        local Highlight = Instance.new("Highlight")
                        Highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
                        Highlight.FillTransparency = 0.3
                        Highlight.OutlineTransparency = 0
                        Highlight.OutlineColor = Color3.fromRGB(255,255,255)
                        Highlight.FillColor = Color
                        Highlight.Adornee = Character
                        Highlight.Parent = Character
