local GunKillRE = {}
local lastGunChosen = nil
local workingGunRemotes = {}
local knownBadGunRemotes = {}

local GunKill = function(target, pos)
    if not target then return end
    pos = pos or Vector3.new(0, 0, 0)
    
    local remotes = {}
    
    for _, child in ipairs(Net:GetChildren()) do
        if child:IsA("RemoteEvent") and string.find(child.Name, "^RE/") then
            local lower = string.lower(child.Name)
            if not string.find(lower, "knifekill") and not string.find(lower, "gunkill") then
                local isBad = false
                for _, bad in ipairs(knownBadGunRemotes) do
                    if bad == child then isBad = true break end
                end
                if not isBad then
                    remotes[#remotes + 1] = child
                end
            end
        end
    end
    
    if #remotes == 0 then return end
    
    local function isAlive(plr)
        local char = plr.Character
        if not char or not char.Parent then return false end
        local hum = char:FindFirstChildOfClass("Humanoid")
        return hum and hum.Health > 0
    end
    
    if #workingGunRemotes > 0 then
        for _, remote in ipairs(workingGunRemotes) do
            local GunKill_args = {
                "9576996e-66e6-4d56-b791-f3b062eb597c",
                target,
                pos
            }
            pcall(function()
                remote:FireServer(unpack(GunKill_args))
            end)
            task.wait(1.1)
            if not isAlive(target) then
                if not GunKillRE[target.Name] then
                    GunKillRE[target.Name] = {}
                end
                table.insert(GunKillRE[target.Name], remote.Name)
                lastGunChosen = remote
                return
            end
        end
        return
    end
    
    local used = {}
    local maxAttempts = #remotes * 2
    local attempt = 0
    
    while isAlive(target) and attempt < maxAttempts do
        local available = {}
        for _, r in ipairs(remotes) do
            if not used[r] then
                available[#available + 1] = r
            end
        end
        
        if #available == 0 then
            for _, r in ipairs(remotes) do
                used[r] = nil
            end
            for _, r in ipairs(remotes) do
                available[#available + 1] = r
            end
        end
        
        lastGunChosen = available[math.random(1, #available)]
        used[lastGunChosen] = true
        attempt = attempt + 1
        
        local GunKill_args = {
            "9576996e-66e6-4d56-b791-f3b062eb597c",
            target,
            pos
        }
        
        local success, err = pcall(function()
            lastGunChosen:FireServer(unpack(GunKill_args))
        end)
        
        if not success then
            knownBadGunRemotes[#knownBadGunRemotes + 1] = lastGunChosen
            for i, r in ipairs(remotes) do
                if r == lastGunChosen then
                    table.remove(remotes, i)
                    break
                end
            end
            task.wait(1.2)
        else
            task.wait(1.3)
            if not isAlive(target) then
                if not GunKillRE[target.Name] then
                    GunKillRE[target.Name] = {}
                end
                table.insert(GunKillRE[target.Name], lastGunChosen.Name)
                if not table.find(workingGunRemotes, lastGunChosen) then
                    workingGunRemotes[#workingGunRemotes + 1] = lastGunChosen
                end
                break
            end
        end
    end
end


