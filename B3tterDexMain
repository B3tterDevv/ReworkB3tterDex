local function throwKnifeAt(target)
    if not target or not target.Character then return false end
    local targetHrp = target.Character:FindFirstChild("HumanoidRootPart")
    if not targetHrp then return false end

    local weapon, remote, handle = getEquippedKnife()
    if not remote or not handle then return false end

    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return false end
    local hrpPos = char.HumanoidRootPart.Position
    local handlePos = handle.Position

    local predictedPos = GetPredictedPosition(target)
    if not predictedPos then return false end

    local lineDir = (predictedPos - hrpPos).Unit
    local handleOffset = handlePos - hrpPos
    local projDistance = handleOffset:Dot(lineDir)
    local correctedOrigin = hrpPos + projDistance * lineDir

    local throwCFrame = CFrame.lookAt(correctedOrigin, predictedPos)
    pcall(function()
        remote:FireServer(throwCFrame, predictedPos)
    end)
    return true
end

local function tryKnifeKillFallback(target)
    if not target.Character or not target.Character:FindFirstChild("HumanoidRootPart") then return false end
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return false end
    local dist = (target.Character.HumanoidRootPart.Position - char.HumanoidRootPart.Position).Magnitude
    if dist > knifeDetectionDist then return false end
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Blacklist
    params.FilterDescendantsInstances = {char}
    local ray = workspace:Raycast(char.HumanoidRootPart.Position, (target.Character.HumanoidRootPart.Position - char.HumanoidRootPart.Position).Unit * dist, params)
    if ray and not ray.Instance:IsDescendantOf(target.Character) then return false end
    if KnifeKill then pcall(function() KnifeKill:FireServer(target, target) end) return true end
    return false
end

local function getClosestVisibleEnemyForKnife()
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return nil end
    local origin = char.HumanoidRootPart.Position
    local enemies = GetEnemyPlayers()
    local best, bestDist = nil, knifeDetectionDist
    for _, enemy in ipairs(enemies) do
        local enemyChar = enemy.Character
        if enemyChar then
            local hrp = enemyChar:FindFirstChild("HumanoidRootPart")
            if hrp then
                local dist = (hrp.Position - origin).Magnitude
                if dist <= bestDist and IfISeeTarget(enemy) then
                    bestDist = dist
                    best = enemy
                end
            end
        end
    end
    return best
end

local function FastThrowKnife()
    if not autoThrow then return end
    local target = getClosestVisibleEnemyForKnife()
    if not target then
        if autoUnequipKnife then UnequipKnife() end
        return
    end
    if not ensureKnifeReady() then
        if autoUnequipKnife then UnequipKnife() end
        return
    end
    local success = throwKnifeAt(target)
    if success then
        tryKnifeKillFallback(target)
        if autoUnequipKnife then
            task.defer(function()
                UnequipKnife()
            end)
        end
    else
        if autoUnequipKnife then
            task.defer(function()
                UnequipKnife()
            end)
        end
    end
end

