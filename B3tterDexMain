local function IsInMatch()
    return #GetEnemyNamesFromFrames() > 0
end

local function JoinGameWithRemote(mode)
    if IsInMatch() then return false end
    local Matchmaking = cloneref(game:GetService("ReplicatedStorage").Packages.Networking["RE/Matchmaking/Matchmaking"])
    if not Matchmaking then return false end
    pcall(function()
        Matchmaking:FireServer("play", { mode = mode })
    end)
    return true
end

