local SafeHttpGet = function(url, retries)
    retries = retries or 2

    if type(url) ~= "string" then
        return nil
    end

    if not url:match("^https?://") then
        return nil
    end

    local function request()
        return _game:HttpGet(url)
    end

    for i = 1, retries do
        local ok, res = xpcall(request, function()
            return nil
        end)

        if ok and res then
            return res
        end

        task.wait(0.3 * i)
    end

    return nil
end

