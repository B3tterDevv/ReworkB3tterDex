UserInputService.InputBegan:Connect(function(Input, GameProcessed)
    if GameProcessed then return end
    local isClick = (Input.UserInputType == Enum.UserInputType.MouseButton1) or
                    (IsTouchDevice and Input.UserInputType == Enum.UserInputType.Touch)
    if not isClick then return end

    if Shoot2DieEnabled and not AllowSlidingKill then
        Shoot2Die()
        return
    end

    if AllowSlidingKill then
        SlidingSessionActive = true
        SlidingKills = {}
        if SlidingConnection then SlidingConnection:Disconnect() end
        SlidingConnection = RunService.Heartbeat:Connect(function()
            if not SlidingSessionActive then return end
            local target = GetClosestEnemyByMouse()
            if target and not SlidingKills[target.Name] then
                SlidingKills[target.Name] = true
                Shoot2Die(true)
            end
        end)
    end
end)

UserInputService.InputEnded:Connect(function(Input)
    local isRelease = (Input.UserInputType == Enum.UserInputType.MouseButton1) or
                      (IsTouchDevice and Input.UserInputType == Enum.UserInputType.Touch)
    if isRelease and AllowSlidingKill then
        SlidingSessionActive = false
        if SlidingConnection then SlidingConnection:Disconnect() SlidingConnection = nil end
        local killedNames = {}
        for name, _ in pairs(SlidingKills) do table.insert(killedNames, name) end
        if #killedNames > 0 then
            Rayfield:Notify({
                Title = lang.SwipeNotifyTitle,
                Content = string.format(lang.SwipeNotifyContent, table.concat(killedNames, ", ")),
                Duration = 3,
                Image = "target"
            })
        end
    end
end)

