local function EquipGun()
    if not AutoEquipEnabled then return nil end
    local Character = LocalPlayer.Character
    if not Character then return nil end
    local Backpack = LocalPlayer:FindFirstChild("Backpack")
    if not Backpack then return nil end
    local equipped, _ = HasWeaponEquipped()
    if equipped then return CurrentGun end
    UnequipKnife()
    CurrentGun = nil
    for _, tool in ipairs(Backpack:GetChildren()) do
        if tool:IsA("Tool") and (tool:FindFirstChild("fire") or tool:FindFirstChild("Fire")) then
            tool.Parent = Character
            task.wait(0.05)
            if tool.Parent == Character then
                CurrentGun = tool
                return tool
            end
        end
    end
    return nil
end

local function EquipKnifeForThrow()
    if not autoEquipKnife then return nil end
    local Character = LocalPlayer.Character
    if not Character then return nil end
    local Backpack = LocalPlayer:FindFirstChild("Backpack")
    if not Backpack then return nil end
    local _, _, equipped = getEquippedKnife()
    if equipped then return CurrentKnife end
    UnequipGun()
    CurrentKnife = nil
    for _, tool in ipairs(Backpack:GetChildren()) do
        if tool:IsA("Tool") and tool:FindFirstChild("Throw") and tool:FindFirstChild("Handle") then
            local hum = Character:FindFirstChildOfClass("Humanoid")
            if hum then
                pcall(function() hum:EquipTool(tool) end)
                task.wait(0.05)
                if tool.Parent == Character then
                    CurrentKnife = tool
                    return tool
                end
            end
        end
    end
    return nil
end

local function ensureKnifeReady()
    local _, _, handle = getEquippedKnife()
    if not handle then
        if autoEquipKnife then EquipKnifeForThrow() end
        return false
    end
    for _ = 1, 7 do
        if handle and handle.Position ~= Vector3.zero then return true end
        task.wait(0.05)
        _, _, handle = getEquippedKnife()
    end
    return handle ~= nil and handle.Position ~= Vector3.zero
end

local function getComp(object, componentName)
    local cacheKey = tostring(object) .. "_" .. componentName
    local cached = cachedComponents[cacheKey]
    if cached and cached.time > tick() - CACHE_INTERVAL then return cached.component end
    local component = object:FindFirstChild(componentName)
    cachedComponents[cacheKey] = { component = component, time = tick() }
    return component
end

local function validWeap(weapon)
    if not weapon then return false end
    local valid = pcall(function() return weapon:IsDescendantOf(game) and weapon.Parent ~= nil end)
    if not valid then return false end
    return getComp(weapon, "fire") ~= nil
end

local BeamBindable = nil
local function GetBeamBindable()
    if BeamBindable and BeamBindable.Parent then
        return BeamBindable
    end
    
    local bindableEvents = ReplicatedStorage:FindFirstChild("BindableEvents")
    if bindableEvents then
        local beam = bindableEvents:FindFirstChild("LocalBeam")
        if beam and beam:IsA("BindableEvent") then
            BeamBindable = beam
            return beam
        end
    end
    
    for _, child in ipairs(ReplicatedStorage:GetChildren()) do
        if child.Name == "LocalBeam" and child:IsA("BindableEvent") then
            BeamBindable = child
            return child
        end
    end
    
    BeamBindable = nil
    return nil
end

local ToolCache = setmetatable({}, {__mode = "k"})

local function GetToolEvents(tool)
    local cached = ToolCache[tool]
    if cached then return cached end
    
    local fireEvent = tool:FindFirstChild("fire") or tool:FindFirstChild("Fire")
    if not fireEvent then return nil end
    
    local events = {
        fire = fireEvent,
        showBeam = tool:FindFirstChild("showBeam"),
        -- kill = tool:FindFirstChild("kill") or tool:FindFirstChild("Kill"),
        handle = tool:FindFirstChild("Handle") or tool
    }
    
    ToolCache[tool] = events
    return events
end

local function Shoot(Target, Pos, isSpam)
    local character = LocalPlayer.Character
    if not character then return false end
    
    local humanoidRootPart = character:FindFirstChild("HumanoidRootPart")
    if not humanoidRootPart then return false end
    
    local toolEvents = nil
    for _, tool in ipairs(character:GetChildren()) do
        if tool:IsA("Tool") then
            toolEvents = GetToolEvents(tool)
            if toolEvents then break end
        end
    end
    
    if not toolEvents then return false end
    
    pcall(function()
        toolEvents.fire:FireServer()
    end)
    
    local beam = GetBeamBindable()
    local usedBeam = false
    if beam then
        usedBeam = true
        pcall(function()
            beam:Fire(toolEvents.handle, Pos)
        end)
    end
    
    local usedShowBeam = false
    if toolEvents.showBeam then
        usedShowBeam = true
        pcall(function()
            toolEvents.showBeam:FireServer(Pos, humanoidRootPart.Position, toolEvents.handle)
        end)
    end
    
    local killed = false
    local remoteUsed = "KnifeKill"
    if UseGunKill then
        remoteUsed = "GunKill"
        GunKill(Target, Pos, false) 
        local char = Target.Character
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        killed = not (hum and hum.Health > 0)
    else
        remoteUsed = "KnifeKill"
        KnifeKill(Target, false) 
        local char = Target.Character
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        killed = not (hum and hum.Health > 0)
    end
    
    if DebugMode then
        Rayfield:Notify({
            Title = lang.DebugModeTitle,
            Content = string.format("%s\n%s\n%s\n%s\n%s\n%s",
                string.format(lang.DebugTriedShoot, Target and Target.Name or "Unknown"),
                string.format(lang.DebugPosition, tostring(Pos)),
                string.format(lang.DebugKilled, killed and "true" or "false"),
                string.format(lang.DebugShootMethod, remoteUsed),
                string.format(lang.DebugUsedBeam, usedBeam and "true" or "false"),
                string.format(lang.DebugUsedShowBeam, usedShowBeam and "true" or "false")
            ),
            Duration = 3
        })
    elseif NotifyWhereShooted then
        Rayfield:Notify({
            Title = lang.ShootingNotify,
            Content = lang.ShootPosContent .. tostring(Pos),
            Duration = 2
        })
    end
    
    return killed
end

local function FastFireTarget(forceTarget)
    if not AutoShootEnabled then return end
    local now = tick()
    local cooldown = COOLDOWN_BASE + (GetPing() / 1000)
    if now - lastShotTime < cooldown then return end
    local Target = forceTarget or GetClosestPlayer()
    if not Target then
        if AutoUnEquipEnabled then UnequipGun() end
        return
    end
    if not AllowShootingWhereYouDontLooking then
        if not LookingEnemy(Target) or not IfISeeTarget(Target) then
            if AutoUnEquipEnabled then UnequipGun() end
            return
        end
    else
        if not IsVisibleNotFOV(Target) then
            if AutoUnEquipEnabled then UnequipGun() end
            return
        end
    end
    local Pos = GetPredictedPosition(Target)
    if not Pos then
        if AutoUnEquipEnabled then UnequipGun() end
        return
    end
    local Eq, Tool = HasWeaponEquipped()
    if not Eq then
        if AutoEquipEnabled then
            Tool = EquipGun()
            if not Tool or Tool.Parent ~= LocalPlayer.Character then return end
        else
            if AutoUnEquipEnabled then UnequipGun() end
            return
        end
    end
    if not validWeap(Tool) then
        if AutoUnEquipEnabled then UnequipGun() end
        return
    end
    local targetName = Target.Name
    Shoot(Target, Pos, false)
    lastShotTime = now
    task.spawn(function()
        task.wait(0.3)
        local target = Players:FindFirstChild(targetName)
        if target then
            local char = target.Character
            local hum = char and char:FindFirstChildOfClass("Humanoid")
            if not (hum and hum.Health > 0) then
                PlayKillSound()
            end
        end
    end)
    if AutoUnEquipEnabled then
        task.delay(0.008, function()
            if CurrentGun and CurrentGun.Parent == LocalPlayer.Character then
                UnequipGun()
            end
        end)
    end
end

